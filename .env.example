# ── GitHub App (preferred — commits appear as app[bot], no personal token) ──────
# Create a GitHub App at github.com → Settings → Developer settings → GitHub Apps
# Permissions: Contents R/W, Pull Requests R/W. Install on this repo.
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=12345678
# Paste the full .pem contents. In .env.local use real newlines; on Netlify use \n.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your-key-here
-----END RSA PRIVATE KEY-----"

# ── Repository ───────────────────────────────────────────────────────────────────
GITHUB_REPO=colin-bishop/global-em

# ── Admin panel ──────────────────────────────────────────────────────────────────
# Validated server-side in Netlify Functions. Leave unset to disable auth (not recommended).
ADMIN_PASSWORD=your-admin-password-here

# ── Frontend (public — safe to commit) ───────────────────────────────────────────
VITE_GITHUB_REPO=colin-bishop/global-em

# ── Local development only ───────────────────────────────────────────────────────
# Serves programs.json from Vite's public folder instead of the GitHub CDN.
# Run: cp data/programs.json app/public/data/programs.json  then uncomment:
VITE_PROGRAMS_URL=/data/programs.json

# ── Deployment subdirectory (optional) ───────────────────────────────────────────
# Set to /global-em/ for GitHub Pages or a path-prefixed deploy; leave unset for root.
# VITE_BASE_PATH=/global-em/
