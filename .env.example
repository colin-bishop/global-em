# Supabase — copy these from your Supabase project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Only used by scripts/export_csv.py — never put in frontend
SUPABASE_SERVICE_KEY=your-service-role-key-here

# GitHub — only used by scripts/export_csv.py
# Create a fine-grained token with Contents: Read & Write on colin-bishop/global-em
GITHUB_TOKEN=your-github-token-here
GITHUB_REPO=colin-bishop/global-em
GITHUB_CSV_PATH=data/programs.csv

# Deployment — set to /global-em/ for GitHub Pages, leave blank for em4.fish root
# VITE_BASE_PATH=/global-em/
